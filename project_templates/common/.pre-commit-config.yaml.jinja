# .pre-commit-config.yaml Template (Platzhalter erlaubt)
# Diese Vorlage legt empfohlene Hooks für das Projekt fest.
# Versionen/Revisionsangaben können über Platzhalter gesetzt werden.

repos:
  - repo: https://github.com/charliermarsh/ruff-pre-commit
    rev: "{{ ruff_rev | default('v0.31.0') }}"
    hooks:
      - id: ruff
        args: ["--fix"]

  - repo: https://github.com/pre-commit/mirrors-isort
    rev: "{{ isort_rev | default('5.12.0') }}"
    hooks:
      - id: isort

  - repo: https://github.com/pre-commit/mirrors-mypy
    rev: "{{ mypy_rev | default('1.0.0') }}"
    hooks:
      - id: mypy
        args: ["--ignore-missing-imports"]

# Hinweis: Weitere Hooks (z. B. markdownlint) können pro Projekt ergänzt werden.
# Siehe PLACEHOLDER_SPEC.md für Platzhalterregeln.
